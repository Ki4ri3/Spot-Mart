<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#050526"
    tools:context=".couriersignup">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=" ✨ Register ✨"
        android:textSize="38sp"
        android:fontFamily="times new roman"
        android:textAlignment="center"
        android:textStyle="bold|italic"
        android:background="@drawable/shape"
        android:padding="12dp"
        android:textColor="#0b0b0b" />

    <!--    Below is a cardview -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="10dp"
        android:layout_margin="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="#a79b90"
            android:padding="12dp">

            <!--            Below is the editText for username -->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="👤Enter User Name"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:fontFamily="times new roman"
                android:textColor="#000"
                android:id="@+id/courier_name"
                android:layout_margin="8dp"
                android:background="#F8F6F6"
                android:padding="10dp" />

            <!--            Below is the editText for email -->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="📧  Enter Email Address"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:fontFamily="times new roman"
                android:textColor="#000"
                android:id="@+id/courier_email"
                android:inputType="textEmailAddress"
                android:layout_margin="8dp"
                android:background="#F8F6F6"
                android:padding="10dp" />

            <!--            Below is the editText for password -->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="🔑  Create password"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="#000"
                android:fontFamily="times new roman"
                android:id="@+id/courier_password"
                android:inputType="textPassword"
                android:layout_margin="8dp"
                android:background="#F8F6F6"
                android:padding="10dp" />

            <!--            Below is the editText for Phone number -->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="📞  Enter your Phone Number"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="#000"
                android:fontFamily="times new roman"
                android:id="@+id/courier_phone"
                android:inputType="number"
                android:layout_margin="8dp"
                android:background="#F8F6F6"
                android:padding="10dp" />

            <!--            Below is the signup Button -->
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👤 Signup"
                android:textSize="25sp"
                android:padding="10dp"
                android:textStyle="bold"
                android:layout_marginLeft="50dp"
                android:layout_marginRight="50dp"
                android:fontFamily="times new roman"
                android:layout_marginTop="25dp"
                android:textColor="#060606"
                android:backgroundTint="#2de206"
                android:id="@+id/couriersignupBtn" />

            <Button
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="More About K-Mart?📜"
                android:textSize="22sp"
                android:padding="10dp"
                android:textStyle="bold"
                android:layout_weight="1"
                android:fontFamily="times new roman"
                android:layout_marginTop="12dp"
                android:layout_marginLeft="40dp"
                android:textColor="#F9FBFB"
                android:backgroundTint="#0D42BD"
                android:id="@+id/aboutBtn"
                />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Already a Courier? Signin"
                android:textAlignment="center"
                android:fontFamily="times new roman"
                android:textSize="23sp"
                android:layout_marginTop="25dp"
                android:textColor="#0013e9"
                android:id="@+id/signintxt" />


        </LinearLayout>

    </androidx.cardview.widget.CardView>



</LinearLayout>