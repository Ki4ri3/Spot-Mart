<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="8dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?android:attr/selectableItemBackground">

    <TextView
        android:id="@+id/product_name"
        android:text="Product Name"
        android:textAlignment="center"
        android:textColor="#0B0B0B"
        android:fontFamily="times new roman"
        android:textSize="30sp"
        android:layout_marginLeft="120dp"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:id="@+id/product_photo"
        android:src="@drawable/welcoming"
        android:scaleType="centerCrop"
        android:layout_marginTop="3dp"/>

    <TextView
        android:id="@+id/product_cost"
        android:text="Price: KES0.00"
        android:textAlignment="center"
        android:textColor="#000007"
        android:textStyle="bold"
        android:fontFamily="times new roman"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp">

        <Button
            android:id="@+id/decrease_btn"
            android:text="-Reduce"
            android:textColor="#faf5ed"
            android:textStyle="bold"
            android:fontFamily="times new roman"
            android:layout_width="wrap_content"
            android:backgroundTint="#eb2517"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/quantity_text"
            android:text="1"
            android:textSize="18dp"
            android:textStyle="bold"
            android:textColor="#000005"
            android:paddingHorizontal="8dp"
            android:fontFamily="times new roman"
            android:gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/increase_btn"
            android:text="+Add"
            android:fontFamily="times new roman"
            android:textStyle="bold"
            android:backgroundTint="#09a233"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/remove_btn"
            android:text="Remove"
            android:textStyle="bold"
            android:backgroundTint="#176eb4"
            android:textColor="#030407"
            android:textSize="18dp"
            android:fontFamily="times new roman"
            android:layout_marginLeft="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>
</LinearLayout>